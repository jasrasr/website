# Project      : AI Writing Tool
# File         : .htaccess
# Revision     : 1.0.0
# Description  : Basic Apache hardening for shared hosting.

Options -Indexes

<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
