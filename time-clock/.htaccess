# Filename   : .htaccess
# Revision   : 1.0.0
# Description: Apache config for time-clock directory; sets default page and blocks credential files
# Author     : Jason Lamb (with help from Claude Code CLI)
# Created    : 2026-04-21
# Modified   : 2026-04-21
# Changelog  :
# 1.0.0  initial release

# Serve index-hostinger.html as the default page
DirectoryIndex index.html

# Block direct access to config and token files
<FilesMatch "^\.(alerts_config|alerts_token)$">
    Order deny,allow
    Deny from all
</FilesMatch>
